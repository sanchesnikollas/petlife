# ─── Database (Supabase) ───
# Use Transaction pooler (port 6543) para API, Direct (port 5432) para migrations
DATABASE_URL=postgresql://postgres.[ref]:[pass]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[ref]:[pass]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ─── Auth ───
JWT_SECRET=change-me-to-a-random-string-32-chars
JWT_REFRESH_SECRET=change-me-to-another-random-string-32-chars

# ─── Cloudflare R2 (file storage) ───
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=petlife-uploads
R2_PUBLIC_URL=https://cdn.petlife.app

# ─── Email (Resend) ───
RESEND_API_KEY=

# ─── Push (Firebase) ───
# Base64-encoded Firebase service account JSON
FCM_SERVICE_ACCOUNT_JSON=

# ─── CORS ───
FRONTEND_URL=https://petlife-web.vercel.app

# ─── Server ───
NODE_ENV=production
PORT=3001
